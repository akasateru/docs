{
  // 保存「前」に 1) フォーマット → 2) 段落番号 の順で実行（Run on Save: pucelle）
  "runOnSave.commands": [
    {
      "globMatch": "**/*.md",
      "commandBeforeSaving": "editor.action.formatDocument",
      "runIn": "vscode",
      "async": false
    },
    {
      "globMatch": "**/*.md",
      "commandBeforeSaving": "markdown.extension.toc.addSecNumbers",
      "runIn": "vscode",
      "async": false
    }
  ],
  "runOnSave.defaultRunIn": "vscode",

  "markdown.extension.toc.updateOnSave": true,
  "markdown.extension.toc.levels": "2..6",

  // マークダウンの設定
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "explicit"
    },
    "editor.quickSuggestions": {
        "comments": "on",
        "strings": "on",
        "other": "on"
    },
    "editor.snippetSuggestions": "top"
  },

  // 画像の保存先をプロジェクトルートの images フォルダに固定
  "pasteImage.path": "${projectRoot}/images",
  "pasteImage.showFilePathConfirmInputBox": true,

  "markdown.copyFiles.destination": {
    "**/*": "${documentWorkspaceFolder}/images/"
  },

  // Marpの設定
  "markdown.marp.html": "all",     // HTML要素を使えるようにする
  "markdown.marp.outline": true,   // アウトライン表示を有効にする

  // MPEの設定（内蔵のMarp機能を有効化）
  "markdown-preview-enhanced.previewConfig.enableMarp": true,
  "markdown-preview-enhanced.hideDefaultVSCodeMarkdownPreviewButtons": false,

  // Pythonの設定
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true
  }
}
